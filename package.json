{
  "name": "youtube-vertical-layout",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "description": "Browser extension: sticky YouTube player, scrollable comments, collapsible recommendations flyout",
  "scripts": {
    "dev": "node scripts/extension-build.mjs chrome --watch",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "node scripts/extension-build.mjs chrome",
    "build:firefox": "node scripts/extension-build.mjs firefox",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "npm run build:chrome && playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.5",
    "@types/webextension-polyfill": "^0.12.1",
    "eslint": "^9.17.0",
    "happy-dom": "^15.11.7",
    "typescript": "^5.7.2",
    "esbuild": "^0.24.2",
    "semver": "^7.6.3",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  }
}
